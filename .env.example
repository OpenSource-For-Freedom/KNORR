# Knörr credentials. Copy to .env and fill in. Real env vars always win over
# this file, and Knörr also reads the shared dev/ root .env and git_warden/.env
# as fallbacks, so an existing Docker/OSM .env works without renaming.

# --- Docker Hub (registry pulls) ---
# A Docker Hub username + access token (dckr_pat_...). The token authenticates
# both `docker login` and the daemonless registry Bearer flow, and lifts the
# pull budget from 100 to 200 per 6h. Accepted fallback names: DOCKER_LOGIN /
# DOCKER_API_KEY (the shared root .env names).
KN_DOCKERHUB_USER=
KN_DOCKERHUB_TOKEN=

# --- OpenSourceMalware (intel in, findings out) ---
# Bearer token (osm_...). Fallback name: GW_OSM_API_KEY (shared with git_warden).
KN_OSM_API_KEY=
# KN_OSM_BASE_URL=https://api.opensourcemalware.com/functions/v1/

# --- Gold/alert channel (confirmed findings only; optional) ---
# Fallback name: GW_DISCORD_WEBHOOK.
KN_ALERT_WEBHOOK=

# --- Optional knobs ---
# KN_WORK_DIR=F:\knorr-work        # keep layer-unpack scratch off the system drive
# KN_PLATFORM_OS=linux
# KN_PLATFORM_ARCH=amd64
